# AI Ecosystem (github.com/benchmarkdupe/ai-ecosystem) opportunity-engine
# base URL, e.g. http://<your-server>:3001. Leave unset to disable this live
# source (it degrades to an empty list, never breaks the build).
AI_ECOSYSTEM_OPPORTUNITY_ENGINE_URL=
# youtube-worker base URL, e.g. http://<your-server>:3002. Optional — used
# to pull real published-video performance (views/likes/comments) onto
# matching AI Ecosystem opportunities as verification signal. Leave unset
# to skip it (no error, just no bonus signal).
AI_ECOSYSTEM_YOUTUBE_WORKER_URL=
# AI_ECOSYSTEM_API_KEY is a secret — set it via your hosting provider's
# environment variables (same as SUPABASE_SERVICE_ROLE_KEY), never commit it
# here. Must match the API_KEY configured on the ai-ecosystem deployment.
# How many fresh ideas to auto-create + research per refresh (from our own
# trending signals) so this feed doesn't sit empty. Defaults to 1 — mind
# ai-ecosystem's free-tier OpenRouter cap (50 req/day) before raising this.
# Set to 0 to disable auto-seeding entirely.
AI_ECOSYSTEM_SEED_PER_REFRESH=1
